// -*- mode: jsonc -*-
{

    // Settings

    "layer": "top", // Waybar at top layer
    "position": "left", // Waybar position (top|bottom|left|right)
    "spacing": 2, // Gaps between modules (4px)
    "margin": 5,
    "width": 30,
    "reload_style_on_change": true,



    // Choose the order of the modules

    "modules-left": [
        "hyprland/workspaces",
    ],
    "modules-center": [
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "network",
        "battery",
        "battery#bat2",
        "clock",
        //"custom/weather",
        "custom/power"
    ],


    // Modules configuration

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "align": "left",
        "warp-on-scroll": false,
        "format": "{name}:{icon}",
        "format-icons": {
            "1": "’äĀ ",
            "2": "’ē© ",
