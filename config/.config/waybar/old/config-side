        "tooltip": true,
        "tooltip-format": "<small>{calendar}</small>",
        "on-click": "gnome-calendar",
        "calendar": {
                "mode"          : "month",
                "weeks-pos"     : "left",
                    "format": {
                                "months":     "<span color='#d4be98'><b>{}</b></span>",
                                "weeks":      "<span color='#7daea3'><b>W{}</b></span>",
                                "weekdays":   "<span color='#d8a657'><b>{}</b></span>",
